<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" style="-fx-padding: 20; -fx-background-color: white;" styleClass="aims-panel-card" stylesheets="@styles2.0.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.controller.ProductManagerController.OrderRejectDialogController">
   <children>
      <Label styleClass="label-header" text="Reject Order" textFill="#d32f2f">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label styleClass="label-subtitle" text="Please select or provide a reason for rejecting this order." />
      
      <ComboBox fx:id="reasonComboBox" prefWidth="400.0" promptText="Select a reason..." style="-fx-font-size: 14px;" styleClass="combo-box" />
      
      <TextArea fx:id="customReasonArea" prefHeight="100.0" prefWidth="400.0" promptText="Or enter a custom reason here..." style="-fx-font-size: 14px;" wrapText="true" />
      
      <Label fx:id="errorLabel" textFill="#d32f2f" visible="false" />
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#handleCancel" prefHeight="38.0" prefWidth="84.0" styleClass="btn-secondary" text="Cancel" />
            <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#handleConfirm" style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" styleClass="btn-primary" text="Confirm Reject" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
