<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900" prefWidth="1600" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.view.UserManagementView">

    <!-- Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;" stylesheets="@styles2.0.css">
            
            <!-- Toolbar -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5;" styleClass="aims-panel-card">
                <Button fx:id="addUserButton" onAction="#handleAddUser" style="-fx-background-color: #4CAF50; -fx-cursor: hand;" styleClass="btn-success" text="➕ Add New User" />
                <Button onAction="#handleRefresh" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand;" styleClass="btn-primary" text="🔄 Refresh" />
                
                <Region HBox.hgrow="ALWAYS" />
                
                <Label style="-fx-font-size: 14px;" text="Filter:" />
                <ComboBox fx:id="filterComboBox" prefWidth="150" style="-fx-background-color: f5f5f5;" styleClass="filter-tab-active" />
                
                <Label fx:id="userCountLabel" style="-fx-font-size: 14px; -fx-text-fill: #666;" text="0 users" />
            </HBox>
            
            <!-- Users Table -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5;" styleClass="aims-panel-card" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 16px;" styleClass="label-section-title" text="All Users" />
                
                <TableView fx:id="userTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" prefWidth="60" text="ID" />
                        <TableColumn fx:id="usernameColumn" prefWidth="120" text="Username" />
                        <TableColumn fx:id="fullNameColumn" prefWidth="150" text="Full Name" />
                        <TableColumn fx:id="rolesColumn" prefWidth="180" text="Roles" />
                        <TableColumn fx:id="statusColumn" prefWidth="80" text="Status" />
                        <TableColumn fx:id="createdAtColumn" prefWidth="140" text="Created At" />
                        <TableColumn fx:id="actionsColumn" prefWidth="230" text="Actions" />
                    </columns>
                    <placeholder>
                        <Label text="No users found" />
                    </placeholder>
                </TableView>
            </VBox>
            
            <!-- Info Panel -->
            <HBox spacing="20" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 5;">
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold;" styleClass="label-section-title" text="Role Information:" />
                    <Label style="-fx-text-fill: #666;" styleClass="label-subtitle" text="• ADMINISTRATOR: Can manage users (create, edit, delete, block/unblock, reset passwords)" />
                    <Label style="-fx-text-fill: #666;" styleClass="label-subtitle" text="• PRODUCT_MANAGER: Can manage products (add, update, delete products)" />
                </VBox>
            </HBox>
            
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;" stylesheets="@styles2.0.css">
            <Button onAction="#handleClose" style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 30; -fx-cursor: hand;" styleClass="btn-secondary" text="Close" />
        </HBox>
    </bottom>
   <top>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="1920.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="95.0" prefWidth="1440.0" spacing="30" style="-fx-background-color: white; -fx-padding: 29 40;">
               <children>
                  <HBox alignment="CENTER" prefHeight="44.0" prefWidth="120.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="44.0" prefWidth="138.0" text="AIMS">
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                           <font>
                              <Font name="Roboto Black" size="28.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label prefHeight="96.0" prefWidth="360.0" text="User Management Panel">
                           <font>
                              <Font name="Roboto Bold" size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Region maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

</BorderPane>
