<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600" prefWidth="550" spacing="15" style="-fx-background-color: #f5f5f5; -fx-padding: 25;" styleClass="aims-panel-card" stylesheets="@styles2.0.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.view.DeliveryInfoDialogUI">
    
    <!-- Header -->
    <VBox alignment="CENTER" spacing="5">
        <Label styleClass="label-header" text="Delivery Information" />
        <Label styleClass="label-subtitle" text="Please fill in all required information to continue" />
    </VBox>
    
    <Separator />
    
    <!-- Form Fields -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: white;" styleClass="aims-panel-card" vbarPolicy="NEVER" VBox.vgrow="ALWAYS">
        <VBox spacing="12" style="-fx-background-color: white;">
            <!-- Full Name -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Full Name *" />
                <TextField fx:id="dialogNameField" promptText="John Doe" style="-fx-font-size: 13px; -fx-padding: 8px;" styleClass="search-box" />
                <Label fx:id="dialogNameError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" text="" visible="false" />
            </VBox>
            
            <!-- Phone Number -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Phone Number *" />
                <TextField fx:id="dialogPhoneField" promptText="0912345678" style="-fx-font-size: 13px; -fx-padding: 8px;" styleClass="search-box" />
                <Label fx:id="dialogPhoneError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" text="" visible="false" />
            </VBox>
            
            <!-- Email -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Email *" />
                <TextField fx:id="dialogEmailField" promptText="email@example.com" style="-fx-font-size: 13px; -fx-padding: 8px;" styleClass="search-box" />
                <Label fx:id="dialogEmailError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-font-weight: 500;" text="" visible="false" />
            </VBox>
            
            <!-- Province/City -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Province/City *" />
                <ComboBox fx:id="dialogProvinceComboBox" maxWidth="Infinity" promptText="Select province/city" style="-fx-font-size: 13px;" styleClass="combo-box" />
                <Label fx:id="dialogProvinceError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" text="" visible="false" />
            </VBox>
            
            <!-- Ward/Commune -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Ward/Subdistrict *" />
                <ComboBox fx:id="dialogWardComboBox" disable="true" maxWidth="Infinity" promptText="Select ward/subdistrict" style="-fx-font-size: 13px;" styleClass="combo-box" />
                <Label fx:id="dialogWardError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" text="" visible="false" />
                <Label fx:id="dialogDeliveryFeeLabel" style="-fx-text-fill: #27ae60; -fx-font-size: 12;" styleClass="label-subtitle" text="Delivery fee: Not calculated yet" />
            </VBox>
            
            <!-- Address -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Detailed Address *" />
                <TextArea fx:id="dialogAddressArea" prefRowCount="2" promptText="House number, street name..." style="-fx-font-size: 13px; -fx-padding: 8px;" styleClass="search-box" wrapText="true" />
                <Label fx:id="dialogAddressError" managed="false" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px;" text="" visible="false" />
            </VBox>
            
            <!-- Delivery Instructions -->
            <VBox spacing="5">
                <Label style="-fx-font-size: 14;" styleClass="label-section-title" text="Delivery Instructions (optional)" />
                <TextArea fx:id="dialogDeliveryInstructionsArea" prefRowCount="2" promptText="Deliver during business hours, call before arrival..." style="-fx-font-size: 13px; -fx-padding: 8px;" styleClass="search-box" wrapText="true" />
            </VBox>
        </VBox>
    </ScrollPane>
    
    <Separator />
    
    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="dialogCancelButton" prefHeight="40.0" prefWidth="100" styleClass="btn-secondary" text="Cancel" />
        <Button fx:id="dialogSaveButton" prefHeight="38.0" prefWidth="152.0" styleClass="btn-success" text="Save Information" />
    </HBox>
</VBox>
