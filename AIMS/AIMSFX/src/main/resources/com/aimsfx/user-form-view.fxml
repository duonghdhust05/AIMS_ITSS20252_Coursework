<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="550" prefWidth="500" xmlns="http://javafx.com/javafx/25"
   xmlns:fx="http://javafx.com/fxml/1"
   fx:controller="com.aimsfx.view.AdministratorView.UserFormView"
   style="-fx-background-color: #f5f5f5;">

   <!-- Form Content -->
   <center>
      <VBox alignment="CENTER" spacing="20" stylesheets="@styles2.0.css" style="-fx-padding: 30;">
         <VBox spacing="15"
            style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">

            <!-- Username -->
            <VBox spacing="5">
               <Label styleClass="label-section-title" stylesheets="@styles2.0.css" text="Username*"
                  style="-fx-font-size: 14px;" />
               <TextField fx:id="usernameField"
                  promptText="Enter username (letters, numbers, underscores)" styleClass="combo-box"
                  style="-fx-font-size: 14px; -fx-padding: 10;" />
            </VBox>

            <!-- Password -->
            <VBox spacing="5">
               <Label fx:id="passwordLabel" styleClass="label-section-title" text="Password*"
                  style="-fx-font-size: 14px;" />
               <PasswordField fx:id="passwordField" promptText="Enter password (min 6 characters)"
                  styleClass="combo-box" style="-fx-font-size: 14px; -fx-padding: 10;" />
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="5">
               <Label fx:id="confirmPasswordLabel" styleClass="label-section-title"
                  text="Confirm Password*" style="-fx-font-size: 14px;" />
               <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password"
                  styleClass="combo-box" style="-fx-font-size: 14px; -fx-padding: 10;" />
               <Label fx:id="passwordHintLabel" text="Password will be hashed before storage"
                  style="-fx-text-fill: #888; -fx-font-size: 11px;" />
            </VBox>

            <!-- Full Name -->
            <VBox spacing="5">
               <Label styleClass="label-section-title" text="Full Name*"
                  style="-fx-font-size: 14px;" />
               <TextField fx:id="fullNameField" promptText="Enter full name" styleClass="combo-box"
                  style="-fx-font-size: 14px; -fx-padding: 10;" />
            </VBox>

            <!-- Roles -->
            <VBox spacing="8">
               <Label styleClass="label-section-title" text="Roles* (select at least one)"
                  style="-fx-font-size: 14px;" />
               <VBox spacing="8" style="-fx-padding: 10; -fx-background-radius: 5;">
                  <CheckBox fx:id="adminRoleCheckBox" styleClass="label-subtitle"
                     text="Administrator - Can manage users">
                     <style>-fx-font-size: 13px;</style>
                  </CheckBox>
                  <CheckBox fx:id="pmRoleCheckBox" styleClass="label-subtitle"
                     text="Product Manager - Can manage products">
                     <style>-fx-font-size: 13px;</style>
                  </CheckBox>
               </VBox>
            </VBox>

            <!-- Error Label -->
            <Label fx:id="errorLabel" text="" wrapText="true"
               style="-fx-text-fill: #f44336; -fx-font-size: 13px;" />

         </VBox>
      </VBox>
   </center>

   <!-- Footer Buttons -->
   <bottom>
      <HBox alignment="CENTER" spacing="15" stylesheets="@styles2.0.css"
         style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
         <Button onAction="#handleSave" styleClass="btn-success" text="💾 Save"
            style="-fx-background-color: #4CAF50; -fx-cursor: hand;" />
         <Button onAction="#handleCancel" prefHeight="41.0" prefWidth="84.0"
            styleClass="btn-secondary" text="Cancel"
            style="-fx-background-color: #9E9E9E; -fx-cursor: hand;" />
      </HBox>
   </bottom>
   <top>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
         minWidth="-Infinity" prefWidth="500.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="95.0" prefWidth="1280.0" spacing="30"
               style="-fx-background-color: white; -fx-padding: 29 40;">
               <children>
                  <HBox alignment="CENTER" prefHeight="37.0" prefWidth="133.0">
                     <children>
                        <Label fx:id="formTitleLabel" alignment="CENTER" prefHeight="44.0"
                           prefWidth="138.0" text="AIMS">
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                           <font>
                              <Font name="Roboto Black" size="28.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label fx:id="formTitleLabel" prefHeight="96.0" prefWidth="360.0"
                           text="Add New User">
                           <font>
                              <Font name="Roboto Bold" size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Region maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0"
                     HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </children>
      </VBox>
   </top>

</BorderPane>