<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900" prefWidth="1600" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.controller.HomepageController">
    
    <!-- Product Grid -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-border-width: 0;" stylesheets="@styles2.0.css">
            <VBox spacing="20" style="-fx-padding: 30 40;">
                <!-- Product Count & Sort -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label fx:id="productCountLabel" style="-fx-text-fill: #666;" styleClass="label-section-title" text="20 products" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="10">
                        <Label styleClass="label-subtitle" text="Sort:" />
                        <Button fx:id="btnSortNew" onAction="#sortByNew" styleClass="sort-btn" text="New" />
                        <Button fx:id="btnSortPriceAsc" onAction="#sortByPriceAsc" styleClass="sort-btn" text="Price ↑" />
                        <Button fx:id="btnSortPriceDesc" onAction="#sortByPriceDesc" styleClass="sort-btn" text="Price ↓" />
                    </HBox>
                </HBox>
                
                <!-- Product Grid -->
                <GridPane fx:id="productGrid" hgap="20" vgap="25">
                    <!-- Products will be dynamically loaded here -->
                </GridPane>
            </VBox>
        </ScrollPane>
    </center>
   <top>
      <VBox alignment="CENTER" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="95.0" prefWidth="1440.0" spacing="30" style="-fx-background-color: white; -fx-padding: 29 40;">
               <children>
                  <HBox alignment="CENTER" prefHeight="44.0" prefWidth="120.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="44.0" prefWidth="138.0" text="AIMS">
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                           <font>
                              <Font name="Roboto Black" size="28.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label prefHeight="96.0" prefWidth="360.0" text="Homepage">
                           <font>
                              <Font name="Roboto Bold" size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Region maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER_RIGHT" prefHeight="44.0" prefWidth="416.0" spacing="15">
                     <children>
                        <HBox alignment="CENTER" prefHeight="44.0" prefWidth="238.0" spacing="10" style="-fx-background-color: #f5f5f5; -fx-background-radius: 5; -fx-padding: 8 15;" HBox.hgrow="NEVER">
                           <children>
                              <TextField fx:id="searchField" prefHeight="25.0" prefWidth="180.0" promptText="Search curated artifacts..." style="-fx-background-color: transparent; -fx-border-width: 0;" HBox.hgrow="NEVER">
                                 <font>
                                    <Font name="Roboto" size="12.0" />
                                 </font>
                              </TextField>
                              <Label style="-fx-font-size: 16px;" text="🔍" />
                           </children>
                        </HBox>
                        <Button onAction="#onAccount" prefHeight="44.0" prefWidth="49.0" style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand;" text="👤" />
                        <StackPane style="-fx-cursor: hand;">
                           <children>
                              <Button onAction="#onCartClick" style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand;" text="🛒" />
                              <Label fx:id="cartBadge" mouseTransparent="true" style="-fx-background-color: red; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 6; -fx-font-size: 10px; -fx-font-weight: bold;" text="0" translateX="10" translateY="-10" />
                           </children>
                        </StackPane>
                     </children>
                  </HBox>
               </children>
            </HBox>
               
                  <!-- Price Filter Tabs -->
               <HBox spacing="0" style="-fx-background-color: white; -fx-padding: 10 40; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" stylesheets="@styles2.0.css">
                   <Button fx:id="btnAll" onAction="#filterAll" prefHeight="42.0" prefWidth="151.0" styleClass="filter-tab-active" text="All" />
                   <Button fx:id="btnUnder100K" onAction="#filterUnder100K" prefHeight="40.0" prefWidth="208.0" styleClass="filter-tab" text="Under 100K" />
                   <Button fx:id="btn100To200K" onAction="#filter100To200K" prefHeight="40.0" prefWidth="207.0" styleClass="filter-tab" text="100K - 200K" />
                   <Button fx:id="btn200To300K" onAction="#filter200To300K" prefHeight="40.0" prefWidth="210.0" styleClass="filter-tab" text="200K - 300K" />
                   <Button fx:id="btnOver300K" onAction="#filterOver300K" prefHeight="40.0" prefWidth="201.0" styleClass="filter-tab" text="Over 300K" />
               <Region prefHeight="42.0" prefWidth="275.0" HBox.hgrow="ALWAYS" />
               <Label prefHeight="42.0" prefWidth="215.0" text="(for Product Manager only)">
                  <font>
                     <Font name="Roboto Bold" size="12.0" />
                  </font>
                  <HBox.margin>
                     <Insets right="20.0" />
                  </HBox.margin>
               </Label>
                    <Button onAction="#onProductManagementPanel" prefHeight="40.0" prefWidth="308.0" style="-fx-cursor: hand;" styleClass="btn-primary" text="Product Management Panel" />
               <Button onAction="#showOrderManagementView" prefHeight="40.0" prefWidth="300.0" style="-fx-cursor: hand;" styleClass="btn-success" text="Order Management Panel">
                  <HBox.margin>
                     <Insets left="20.0" />
                  </HBox.margin>
               </Button>
               </HBox>
         </children>
      </VBox>
   </top>
</BorderPane>
