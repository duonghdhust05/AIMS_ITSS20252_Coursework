<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="15.0" style="-fx-padding: 15; -fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;" styleClass="aims-panel-card" stylesheets="@styles2.0.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.controller.PlaceOrderController.CartItemController">
   <children>
      <Label fx:id="imageLabel" style="-fx-font-size: 40px; -fx-pref-width: 80; -fx-pref-height: 80; -fx-alignment: center; -fx-background-color: #f5f5f5; -fx-background-radius: 5;" />
      <VBox prefWidth="300.0" spacing="5.0">
         <children>
            <Label fx:id="nameLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;" />
            <Label fx:id="priceLabel" style="-fx-font-size: 13px; -fx-text-fill: #666;" />
            <Label fx:id="stockLabel" style="-fx-font-size: 11px; -fx-text-fill: #999;" />
            <HBox alignment="CENTER_LEFT" spacing="5.0">
               <children>
                  <Button fx:id="minusBtn" onAction="#handleMinus" style="-fx-background-color: #f5f5f5; -fx-cursor: hand; -fx-font-size: 14px; -fx-padding: 2 8;" text="-" />
                  <Label fx:id="quantityLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 2 10; -fx-text-fill: #333;" />
                  <Button fx:id="plusBtn" onAction="#handlePlus" style="-fx-background-color: #f5f5f5; -fx-cursor: hand; -fx-font-size: 14px; -fx-padding: 2 8;" text="+" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Region HBox.hgrow="ALWAYS" />
      <VBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Label fx:id="subtotalLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ff5722;" />
            <Button fx:id="removeBtn" onAction="#handleRemove" style="-fx-background-color: #ffebee; -fx-text-fill: #c62828; -fx-cursor: hand; -fx-background-radius: 3; -fx-font-size: 12px;" styleClass="btn-primary" text="🗑 Remove" />
         </children>
      </VBox>
   </children>
</HBox>
