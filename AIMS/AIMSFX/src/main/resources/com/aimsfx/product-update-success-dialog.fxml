<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" styleClass="aims-panel-card" stylesheets="@styles2.0.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.view.ProductView.ProductUpdateSuccessDialog">
   <padding>
      <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
   </padding>
   
   <Label  styleClass="label-header" text="✓ Product Updated Successfully!"  style="-fx-font-size: 20; -fx-text-fill: #4CAF50;"/>
   
   <VBox alignment="CENTER" spacing="10">
      <Label fx:id="productTitleLabel"  styleClass="label-section-title" text="Product Title"  style="-fx-font-size: 16;"/>
      <Label fx:id="productDetailsLabel"  styleClass="label-subtitle" text="Product Details" textAlignment="CENTER"  style="-fx-font-size: 12;"/>
   </VBox>
   
   <Button fx:id="closeButton" onAction="#handleClose" styleClass="btn-primary" text="Close" />
</VBox>
