<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720" prefWidth="1280" xmlns="http://javafx.com/javafx/25"
   xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.view.ProductView.ProductListView">
   <center>
      <VBox spacing="10" stylesheets="@styles2.0.css">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </padding>
         <HBox alignment="CENTER_RIGHT" spacing="10">
            <Label style="-fx-font-size: 18; -fx-font-weight: bold;"
               styleClass="label-section-title" text="All Products" />
            <Region prefHeight="0.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Label fx:id="selectionCountLabel" style="-fx-font-size: 14; -fx-text-fill: #666;"
               styleClass="label-subtitle" text="Selected: 0/10" />
            <Button fx:id="deleteSelectedButton" disable="true" onAction="#handleDeleteSelected"
               style="-fx-background-color: #f44336; -fx-text-fill: white;" styleClass="btn-primary"
               text="Delete Selected" />
            <Button fx:id="addProductButton" onAction="#onAddProduct"
               style="-fx-background-color: #2196F3; -fx-text-fill: white;" styleClass="btn-primary"
               text="Add Product" />
         </HBox>
         <TableView fx:id="productTableView" prefHeight="400.0">
            <columns>
               <TableColumn fx:id="selectColumn" prefWidth="50.0" text="Select" />
               <TableColumn fx:id="barcodeColumn" prefWidth="150.0" text="Barcode" />
               <TableColumn fx:id="titleColumn" prefWidth="250.0" text="Title" />
               <TableColumn fx:id="typeColumn" prefWidth="127.0" text="Type" />
               <TableColumn fx:id="stockColumn" prefWidth="127.0" text="Stock" />
               <TableColumn fx:id="actionsColumn" prefWidth="226.0" text="Actions" />
               <TableColumn fx:id="statusColumn" prefWidth="210.0" text="Status" />
            </columns>
         </TableView>
         <BorderPane.margin>
            <Insets top="30.0" />
         </BorderPane.margin>
      </VBox>
   </center>
   <top>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
         minWidth="-Infinity" prefWidth="1920.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="95.0" prefWidth="1440.0" spacing="30"
               style="-fx-background-color: white; -fx-padding: 29 40;">
               <children>
                  <HBox alignment="CENTER" prefHeight="44.0" prefWidth="120.0">
                     <children>
                        <Label alignment="CENTER" prefHeight="44.0" prefWidth="138.0" text="AIMS">
                           <cursor>
                              <Cursor fx:constant="HAND" />
                           </cursor>
                           <font>
                              <Font name="Roboto Black" size="28.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox prefHeight="44.0" prefWidth="242.0">
                     <children>
                        <Label prefHeight="44.0" prefWidth="269.0" text="Product Management System">
                           <font>
                              <Font name="Roboto Bold" size="18.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <Region maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="200.0"
                     HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER_RIGHT" prefHeight="44.0" prefWidth="416.0" spacing="15">
                     <children>
                        <Button prefHeight="44.0" prefWidth="49.0"
                           style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand;"
                           text="👤" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
</BorderPane>