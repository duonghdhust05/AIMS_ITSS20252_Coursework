<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720" prefWidth="1280" style="-fx-background-color: white;"
    xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.aimsfx.view.PaymentUI.PaymentUI">

    <fx:define>
        <ToggleGroup fx:id="paymentMethodGroup" />
    </fx:define>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #f5f5f5;"
            stylesheets="@styles2.0.css" vbarPolicy="NEVER">
            <content>
                <HBox spacing="40" style="-fx-padding: 30 60;">

                    <VBox spacing="25" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label style="-fx-font-size: 24px; -fx-font-weight: bold;"
                                text="Payment Method" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleBack" style="-fx-cursor: hand;"
                                styleClass="btn-secondary" text="Cancel / Back" />
                        </HBox>

                        <VBox fx:id="vietqrBox" spacing="15" style="-fx-cursor: hand;"
                            styleClass="aims-panel-card">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <!-- VietQR has no radio button - it's the default payment method -->
                                <RadioButton fx:id="vietqrRadio" managed="false" selected="true"
                                    visible="false" toggleGroup="$paymentMethodGroup" />
                                <Label styleClass="label-section-title" text="VietQR" />
                                <Label
                                    style="-fx-background-color: #e3f2fd; -fx-text-fill: #0d47a1; -fx-padding: 3 10; -fx-background-radius: 3; -fx-font-size: 11px; -fx-font-weight: bold;"
                                    text="Recommended" />
                                <Region HBox.hgrow="ALWAYS" />
                            </HBox>

                            <Label styleClass="label-subtitle"
                                text="Scan with any mobile banking app (Vietcombank, MBBank, etc.)" />

                            <VBox fx:id="qrCodeContainer" alignment="CENTER" spacing="10"
                                style="-fx-background-color: #fafafa; -fx-padding: 20; -fx-background-radius: 5;">
                                <StackPane>
                                    <ImageView fx:id="qrCodeImageView" fitHeight="250"
                                        fitWidth="250" preserveRatio="true" />
                                    <ProgressIndicator fx:id="loadingIndicator" maxHeight="50"
                                        maxWidth="50" visible="false" />
                                </StackPane>

                                <HBox alignment="CENTER" spacing="5">
                                    <Label style="-fx-font-size: 14px;"
                                        styleClass="label-section-title" text="Total:" />
                                    <Label fx:id="totalLabelInQR" style="-fx-text-fill: #d32f2f;"
                                        styleClass="label-price" text="..." />
                                </HBox>

                                <Label fx:id="transactionIdLabel"
                                    style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"
                                    text="..." />
                                <Label style="-fx-font-style: italic;" styleClass="label-subtitle"
                                    text="Payment verifies automatically in seconds" />
                            </VBox>
                        </VBox>

                        <VBox fx:id="paypalBox" spacing="15" style="-fx-cursor: hand;"
                            styleClass="aims-panel-card">
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <RadioButton fx:id="paypalRadio" style="-fx-font-size: 14px;"
                                    toggleGroup="$paymentMethodGroup" />
                                <Label styleClass="label-section-title" text="PayPal" />
                            </HBox>
                            <Label styleClass="label-subtitle"
                                text="Pay securely with your PayPal account or Credit Card" />
                        </VBox>

                        <Region prefHeight="50" />
                    </VBox>

                    <VBox prefWidth="320" spacing="20" styleClass="aims-panel-card">
                        <Label style="-fx-font-size: 18px;" styleClass="label-header"
                            text="Order Summary" />

                        <VBox spacing="12">
                            <Separator />
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 16px;" styleClass="label-section-title"
                                    text="Total" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="totalLabel"
                                    style="-fx-font-size: 20px; -fx-text-fill: #d32f2f;"
                                    styleClass="label-price" text="..." />
                            </HBox>
                        </VBox>
                        <Separator />

                        <Region VBox.vgrow="ALWAYS" />

                        <Button fx:id="btnConfirmPayment" maxWidth="Infinity"
                            onAction="#handleConfirmPayment"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 20; -fx-cursor: hand;"
                            styleClass="btn-warning" text="Confirm Payment" />
                    </VBox>
                </HBox>
            </content>
        </ScrollPane>
    </center>
    <top>
        <VBox alignment="CENTER" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="95.0" spacing="30"
                    style="-fx-background-color: white; -fx-padding: 29 40;">
                    <children>
                        <HBox alignment="CENTER" prefHeight="44.0" prefWidth="120.0">
                            <children>
                                <Label alignment="CENTER" prefHeight="44.0" prefWidth="138.0"
                                    text="AIMS">
                                    <cursor>
                                        <Cursor fx:constant="HAND" />
                                    </cursor>
                                    <font>
                                        <Font name="Roboto Black" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                        <HBox prefHeight="100.0" prefWidth="200.0">
                            <children>
                                <Label prefHeight="96.0" prefWidth="360.0" text="Payment Process">
                                    <font>
                                        <Font name="Roboto Bold" size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                        <Region maxWidth="1.7976931348623157E308" prefHeight="200.0"
                            prefWidth="200.0" HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT" prefHeight="44.0" prefWidth="416.0"
                            spacing="15">
                            <children>
                                <Button prefHeight="44.0" prefWidth="49.0"
                                    style="-fx-background-color: transparent; -fx-font-size: 20px; -fx-cursor: hand;"
                                    text="👤" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
</BorderPane>