            <VBox.margin>
               <Insets />
            </VBox.margin>
            </HBox>
            <TableView fx:id="ordersTable" prefHeight="842.0" prefWidth="1880.0">
                <columns>
                    <TableColumn prefWidth="90.0" text="Order ID" />
                    <TableColumn prefWidth="160.0" text="Created At" />
                    <TableColumn prefWidth="240.0" text="Customer" />
                    <TableColumn prefWidth="140.0" text="Total" />
                    <TableColumn prefWidth="140.0" text="Status" />
                    <TableColumn prefWidth="260.0" text="Actions" />
                </columns>
            </TableView>
            <Pagination />
        </VBox>
    </center>
   <top>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefWidth="1920.0" BorderPane.alignment="CENTER">
