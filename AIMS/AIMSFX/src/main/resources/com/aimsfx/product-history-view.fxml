<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="15.0" stylesheets="@styles2.0.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="label-header" text="Edit History" />
      <Label style="-fx-text-fill: #666666;" styleClass="label-subtitle" text="All versions of this product (newest first). Current version is highlighted." />
      <TableView fx:id="historyTable" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
      <Button fx:id="closeButton" onAction="#handleClose" styleClass="btn-secondary" text="Close" />
   </children>
</VBox>
