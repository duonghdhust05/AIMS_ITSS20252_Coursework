<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="600.0" prefWidth="600.0" stylesheets="@styles2.0.css"
   xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
   fx:controller="com.aimsfx.view.OrderView.OrderDetailDialogUI">
   <content>
      <VBox spacing="20.0" style="-fx-padding: 20; -fx-background-color: white;">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Label styleClass="label-header" text="Order Details" textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>

            <GridPane hgap="15.0" style="-fx-padding: 10; -fx-border-radius: 20;"
               styleClass="table-view" vgap="10.0">
               <children>
                  <Label styleClass="label-subtitle" text="Order ID:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="0">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="orderIdLabel" GridPane.columnIndex="1" GridPane.rowIndex="0">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>

                  <Label styleClass="label-subtitle" text="Status:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="1">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="statusLabel" GridPane.columnIndex="1" GridPane.rowIndex="1">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>

                  <Label styleClass="label-subtitle" text="Total Amount:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="2">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="totalAmountLabel" textFill="#27ae60" GridPane.columnIndex="1"
                     GridPane.rowIndex="2">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>

                  <Label styleClass="label-subtitle" text="Payment Method:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="3">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
                  <Label fx:id="paymentMethodLabel" GridPane.columnIndex="1" GridPane.rowIndex="3">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
               </children>
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
            </GridPane>

            <Label styleClass="label-section-title" text="Delivery Information" textFill="#34495e">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>

            <GridPane hgap="15.0" style="-fx-padding: 10; -fx-border-radius: 20;"
               styleClass="table-view" vgap="10.0">
               <children>
                  <Label styleClass="label-subtitle" text="Name:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Label fx:id="deliveryNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label styleClass="label-subtitle" text="Phone:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Label fx:id="deliveryPhoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label styleClass="label-subtitle" text="Email:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <Label fx:id="deliveryEmailLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                  <Label styleClass="label-subtitle" text="Address:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="3" />
                  <Label fx:id="deliveryAddressLabel" wrapText="true" GridPane.columnIndex="1"
                     GridPane.rowIndex="3" />

                  <Label styleClass="label-subtitle" text="Instructions:" textFill="#7f8c8d"
                     GridPane.columnIndex="0" GridPane.rowIndex="4" />
                  <Label fx:id="deliveryInstructionsLabel" wrapText="true" GridPane.columnIndex="1"
                     GridPane.rowIndex="4" />
               </children>
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
            </GridPane>

            <Label styleClass="label-section-title" text="Order Items" textFill="#34495e">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>

            <TableView fx:id="itemsTable" prefHeight="200.0" prefWidth="200.0">
               <columns>
                  <TableColumn fx:id="colProduct" prefWidth="250.0" text="Product" />
                  <TableColumn fx:id="colQuantity" prefWidth="75.0" text="Qty" />
                  <TableColumn fx:id="colUnitPrice" prefWidth="100.0" text="Unit Price" />
                  <TableColumn fx:id="colTotal" prefWidth="100.0" text="Total" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose"
                     prefWidth="100.0" styleClass="btn-secondary" text="Close" />
               </children>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </content>
</ScrollPane>