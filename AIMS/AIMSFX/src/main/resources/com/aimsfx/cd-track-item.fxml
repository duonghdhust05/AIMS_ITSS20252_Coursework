<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1; -fx-background-radius: 3;" stylesheets="@styles2.0.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aimsfx.controller.ProductManagerController.CDTrackItemController">
   <padding>
      <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
   </padding>
   <children>
      <Label fx:id="numberLabel" prefWidth="30.0" style="-fx-font-weight: bold;" />
      <Label fx:id="titleLabel" prefWidth="300.0" />
      <Label fx:id="durationLabel" prefWidth="80.0" style="-fx-text-fill: #666;" />
      <Button fx:id="removeBtn" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 5 10;" styleClass="btn-primary" text="Remove" />
   </children>
</HBox>
